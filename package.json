{
  "name": "@bepalo/router",
  "version": "2.14.40",
  "description": "A fast and feature-rich router for JavaScript runtimes.",
  "author": "Natnael Eshetu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bepalo/router.git"
  },
  "homepage": "https://github.com/bepalo/router#readme",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./src": {
      "import": "./src/index.ts"
    },
    "./src/*": {
      "import": "./src/*"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "src/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build:esm": "tsc --project tsconfig.esm.json",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build": "concurrently \"pnpm run build:esm\" \"pnpm run build:cjs\"",
    "build:watch": "concurrently \"tsc --watch --project tsconfig.esm.json\" \"tsc --watch --project tsconfig.cjs.json\"",
    "prepublishOnly": "pnpm run build",
    "test": "vitest --reporter=dot",
    "test:ci": "vitest run --reporter=vitest-markdown-reporter --outputFile=test-result.md"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "@types/node": "^24.0.13",
    "concurrently": "^9.2.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "vitest-markdown-reporter": "^0.1.2"
  },
  "keywords": [
    "router",
    "rest",
    "http",
    "https",
    "middleware"
  ],
  "dependencies": {
    "@bepalo/cache": "^1.0.3",
    "@bepalo/jwt": "^2.0.9",
    "@bepalo/time": "^1.2.11"
  }
}
