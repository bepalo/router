{
  "name": "@bepalo/router",
  "version": "1.11.32",
  "description": "A fast and feature-rich router for JavaScript runtimes.",
  "author": "Natnael Eshetu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bepalo/router.git"
  },
  "homepage": "https://github.com/bepalo/router#readme",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build:esm": "tsc --project tsconfig.esm.json",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build": "concurrently \"pnpm run build:esm\" \"pnpm run build:cjs\"",
    "build:watch": "concurrently \"tsc --watch --project tsconfig.esm.json\" \"tsc --watch --project tsconfig.cjs.json\"",
    "prepare": "pnpm run build",
    "test": "vitest --reporter=dot",
    "test:ci": "vitest run --reporter=vitest-markdown-reporter --outputFile=test-result.md"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "@types/node": "^24.0.13",
    "concurrently": "^9.2.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "vitest-markdown-reporter": "^0.1.2"
  },
  "keywords": [
    "router",
    "rest",
    "http",
    "https",
    "middleware"
  ],
  "dependencies": {
    "@bepalo/cache": "^1.0.3",
    "@bepalo/jwt": "^2.0.9",
    "@bepalo/time": "^1.2.11"
  }
}
